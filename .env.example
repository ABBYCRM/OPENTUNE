# OPENTUNE environment variables (sample only — never commit real values)
# Hardware transport selection
OPENTUNE_TRANSPORT=elm327
OPENTUNE_DEVICE=/dev/ttyUSB0
OPENTUNE_BAUD=38400

# Bluetooth (when OPENTUNE_TRANSPORT=elm327-bt)
OPENTUNE_BT_ADDRESS=

# OpenTune HW (custom serial interface)
OPENTUNE_HW_PORT=
OPENTUNE_HW_BAUD=921600

# J2534 path (Windows)
OPENTUNE_J2534_DLL=

# App
NODE_ENV=development
LOG_LEVEL=info
